{
  "model_architecture": {
    "hidden_size": 2560,
    "num_hidden_layers": 3,
    "layers_per_expert_block": 8,
    "max_seq_len": 512,
    "causal": true,
    "num_attention_heads": 32,
    "num_key_value_heads": 8,
    "dropout_p": 0.0,
    "norm_eps": 1e-6,
    "ffn_hidden_expansion": 2.0
  },
  "router": {
    "router_keep_policy": "quota",
    "router_temperature": 1.8,
    "router_keep_rate_target": 0.55,
    "router_keep_penalty_coeff": 0.10,
    "router_lb_coeff": 0.30,
    "router_entropy_coeff": 0.01,
    "router_aux_loss_coeff": 0.05
  },
  "adapters": {
    "lora_depths": [2],
    "lora_num": 1,
    "lora_rank": 2,
    "lora_alpha": 1.0,
    "lora_temperature": 1.2,
    "lora_gate_hidden": 0,
    "lora_usage_target": 0.10,
    "lora_usage_coeff": 0.01
  },
  "data_and_paths": {
    "tokenizer_path": "./Qwen3-4B",
    "processed_dataset_path": "./wikitext_processed_qwen",
    "save_dir": "./checkpoints"
  },
  "training": {
    "device": "cuda:0",
    "precision": "bf16",
    "num_workers": 8,
    "batch_size": 16,
    "optimizer": "adamw8bit",
    "lr": 3e-5,
    "beta1": 0.9,
    "beta2": 0.95,
    "weight_decay": 0.0,
    "warmup_steps": 2000,
    "gradient_accumulation_steps": 16,
    "train_epochs": 10,
    "seed": 123,
    "log_interval": 100,
    "early_eval": true,
    "early_eval_steps": 1000,
    "early_eval_interval": 100,
    "early_eval_max_batches": 16
  }
}
